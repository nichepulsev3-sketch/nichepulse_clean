# =====================================================
# NICHEPULSE — Variables de entorno
# Copia este archivo como .env.local y rellena los valores
# NUNCA subas .env.local a GitHub
# =====================================================

# URL de tu app (en local: http://localhost:3000 | en Vercel: https://tuapp.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- SUPABASE ---
# Consíguelas en: supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=eyXXXXXXXXXXXXXXXXXXXX

# --- STRIPE ---
# Consíguelas en: dashboard.stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXX
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXX
# IDs de precios (dashboard.stripe.com → Product catalog → copia el Price ID)
STRIPE_PRICE_PRO_MONTHLY=price_XXXXXXXXXXXX
STRIPE_PRICE_AGENCY_MONTHLY=price_XXXXXXXXXXXX

# --- ANTHROPIC ---
# Consíguelo en: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXX

# --- OpenAI (opcional — acelera búsquedas Pro/Agency) ---
# platform.openai.com/api-keys
# Con esto se usa Claude + GPT-4o-mini en paralelo. El que responde primero gana.
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_OPTIONAL
